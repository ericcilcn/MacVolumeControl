---
import DynamicOsdDemo from "./DynamicOsdDemo.astro";
import InputVolumeDemo from "./InputVolumeDemo.astro";
import { SITE } from "../data/site";

interface Props {
  locale?: "zh" | "en";
}

const { locale = "zh" } = Astro.props;
const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base}${path.replace(/^\/+/, "")}`;

const content = {
  zh: {
    badge: "macOS 菜单栏音量工具",
    headline: "Rolume",
    subheadline: "滚一下，音量就到位",
    intro: "用鼠标滚轮、触控板滑动或修饰键，快速调节 Mac 当前声音输出。轻量、开源，不打扰。",
    primaryCta: `下载 Rolume ${SITE.version}`,
    secondaryCta: "查看源码",
    unsignedNote: "当前公开测试版尚未签名。首次运行时，macOS 可能需要你手动确认打开。",
    demo: {
      desktopTitle: "把光标放进这个窗口",
      desktopCopy: "滚动或双指滑动",
      touchTitle: "轻点这个窗口",
      touchCopy: "然后上下滑动试用",
      touchActiveTitle: "上下滑动调节音量",
      touchActiveCopy: "点到窗口外即可继续滚动页面",
    },
    device: {
      kicker: "声音输出",
      title: "支持你正在使用的设备",
      body: "Rolume 跟随 macOS 当前输出；显示器可用时通过 DDC/CI 控制。",
      outputs: [
        ["外接显示器", "支持 DDC/CI 时可直接控制显示器扬声器。", "/device-icons/display.svg"],
        ["MacBook", "跟随当前系统输出，内置扬声器也能顺手调。", "/device-icons/macbook.svg"],
        ["耳机 / AirPods", "切到耳机后，滚动手感保持一致。", "/device-icons/airpods.svg"],
        ["AirPlay", "作为当前声音输出时，同样用 Rolume 调节。", "/device-icons/airplay.svg"],
      ],
    },
    settings: {
      kicker: "设置",
      title: "该调的地方，都在这里",
      body: "显示器音量、滚动步进、触发区域和鼠标反转。设好一次，平时就留在菜单栏。",
      beforeStrong: "通用页处理输出设备，鼠标页处理滚动手感。",
      strong: "单独反转鼠标滚轮方向",
      afterStrong: "也在这里，不必再为这一个习惯额外装一款工具。",
      generalAlt: "Rolume 通用设置窗口，显示 R27U81 外接显示器音量和常用开关。",
      mouseAlt: "Rolume 鼠标设置窗口，显示步进幅度、滚动调节音量和滚轮反转选项。",
      points: [
        ["显示器音量", "独立滑块和设备名称"],
        ["滚动手感", "区域、步进和修饰键"],
        ["设备分开", "鼠标与触控板独立设置"],
        ["鼠标滚轮反转", "只反转鼠标，不影响触控板；可排除特定 App。"],
      ],
    },
    osd: {
      kicker: "反馈",
      title: "滚动时，只提示结果",
      body: "OSD 显示设备名和音量条，短暂出现，然后回到你的工作里。",
    },
    download: {
      kicker: "下载",
      title: "从 GitHub Releases 获取",
      body: "开源发布，安装包和更新记录都放在 GitHub。需要滚轮反转或拦截滚动时，再按需开启辅助功能权限。",
      button: "下载 DMG",
      releases: "所有版本",
    },
  },
  en: {
    badge: "macOS menu bar volume utility",
    headline: "Rolume",
    subheadline: "Scroll once. Volume follows.",
    intro: "Adjust the current Mac audio output with a mouse wheel, trackpad gesture, or modifier key. Lightweight, open source, and out of your way.",
    primaryCta: `Download Rolume ${SITE.version}`,
    secondaryCta: "View source",
    unsignedNote: "This public beta is not signed yet. On first launch, macOS may ask you to confirm opening the app manually.",
    demo: {
      desktopTitle: "Move your pointer here",
      desktopCopy: "Scroll or use a two-finger gesture",
      touchTitle: "Tap this preview",
      touchCopy: "Then swipe up or down",
      touchActiveTitle: "Swipe to adjust volume",
      touchActiveCopy: "Tap outside to scroll the page again",
    },
    device: {
      kicker: "Audio output",
      title: "Works with the device you are using",
      body: "Rolume follows the current macOS output. External displays can be controlled through DDC/CI when available.",
      outputs: [
        ["External display", "Control display speakers directly when DDC/CI is available.", "/device-icons/display.svg"],
        ["MacBook", "Works with the built-in speakers when they are the current output.", "/device-icons/macbook.svg"],
        ["Headphones / AirPods", "Keep the same scrolling feel after switching to headphones.", "/device-icons/airpods.svg"],
        ["AirPlay", "When AirPlay is the active output, Rolume follows it too.", "/device-icons/airplay.svg"],
      ],
    },
    settings: {
      kicker: "Settings",
      title: "The useful controls, in one place",
      body: "Display volume, scroll steps, trigger areas, and mouse reversal. Set it once, then leave Rolume in the menu bar.",
      beforeStrong: "General settings handle outputs; Mouse settings handle scrolling feel. ",
      strong: "Mouse wheel reversal",
      afterStrong: " is built in, so you do not need another utility just for that habit.",
      generalAlt: "Rolume General settings window showing R27U81 external display volume and common toggles.",
      mouseAlt: "Rolume Mouse settings window showing step size, scroll-to-volume options, and mouse wheel reversal.",
      points: [
        ["Display volume", "Separate slider and device name"],
        ["Scroll feel", "Areas, steps, and modifier keys"],
        ["Separate devices", "Mouse and trackpad stay independent"],
        ["Mouse wheel reversal", "Reverse only the mouse; exclude specific apps."],
      ],
    },
    osd: {
      kicker: "Feedback",
      title: "Only the result appears",
      body: "The OSD shows the device name and volume bar, then quickly gets out of the way.",
    },
    download: {
      kicker: "Download",
      title: "Get it from GitHub Releases",
      body: "Rolume is open source. Builds and release notes live on GitHub. Accessibility permission is only needed for reversal or scroll interception.",
      button: "Download DMG",
      releases: "All releases",
    },
  },
};

const copy = content[locale];
---

<section class="overflow-hidden border-b border-[color:var(--line)]">
  <div class="mx-auto grid min-h-[78svh] max-w-6xl items-center gap-10 px-5 py-16 lg:grid-cols-[0.92fr_1.08fr]">
    <div class="min-w-0 max-w-2xl">
      <p class="mb-5 inline-flex rounded-[8px] border border-[color:var(--line)] bg-white px-3 py-1 text-sm font-medium text-[color:var(--muted)]">
        {copy.badge}
      </p>
      <h1 class="max-w-4xl text-5xl font-semibold leading-[0.98] tracking-normal text-[color:var(--ink)] sm:text-7xl">
        {copy.headline}
      </h1>
      <h2 class="mt-5 max-w-3xl text-3xl font-semibold leading-tight tracking-normal text-[color:var(--ink)] sm:text-4xl">
        {copy.subheadline}
      </h2>
      <p class="mt-5 max-w-2xl text-xl leading-8 text-[color:var(--muted)]">
        {copy.intro}
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          class="inline-flex min-h-12 items-center justify-center rounded-[8px] bg-[color:var(--ink)] px-5 py-3 text-sm font-semibold text-white transition hover:bg-black"
          href={SITE.downloadUrl}
        >
          {copy.primaryCta}
        </a>
        <a
          class="inline-flex min-h-12 items-center justify-center rounded-[8px] border border-[color:var(--line)] bg-white px-5 py-3 text-sm font-semibold text-[color:var(--ink)] transition hover:bg-[color:var(--surface-muted)]"
          href={SITE.repositoryUrl}
        >
          {copy.secondaryCta}
        </a>
      </div>
      <p class="mt-5 text-sm leading-6 text-[color:var(--muted)]">
        {copy.unsignedNote}
      </p>
    </div>
    <div class="min-w-0 lg:justify-self-end">
      <InputVolumeDemo {...copy.demo} />
    </div>
  </div>
</section>

<section class="border-b border-[color:var(--line)] bg-white">
  <div class="mx-auto max-w-6xl px-5 py-16">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold tracking-normal text-[color:var(--blue)]">{copy.device.kicker}</p>
      <h2 class="mt-3 text-3xl font-semibold leading-tight tracking-normal text-[color:var(--ink)] sm:text-4xl">
        {copy.device.title}
      </h2>
      <p class="mt-4 max-w-2xl leading-7 text-[color:var(--muted)]">
        {copy.device.body}
      </p>
    </div>
    <div class="mt-9 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        copy.device.outputs.map(([title, description, icon]) => (
          <article class="feature-card group p-5 transition duration-200 hover:-translate-y-1 hover:shadow-[0_22px_42px_rgba(18,20,23,0.10)]">
            <span class="grid h-14 w-14 place-items-center rounded-[8px] border border-[color:var(--line)] bg-white shadow-[0_8px_18px_rgba(18,20,23,0.06)]">
              <img class="max-h-8 max-w-9" src={withBase(icon)} alt="" loading="lazy" decoding="async" />
            </span>
            <h3 class="mt-5 text-base font-semibold tracking-normal text-[color:var(--ink)]">{title}</h3>
            <p class="mt-2 text-sm leading-6 text-[color:var(--muted)]">{description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<section class="mx-auto max-w-6xl px-5 py-16">
  <div class="product-showcase">
    <div class="screenshot-stack" aria-label="Rolume settings window screenshots">
      <figure class="stacked-shot stacked-shot-general">
        <img src={withBase("/screenshots/general-settings.png")} alt={copy.settings.generalAlt} loading="eager" decoding="async" />
      </figure>
      <figure class="stacked-shot stacked-shot-mouse">
        <img src={withBase("/screenshots/mouse-settings.png")} alt={copy.settings.mouseAlt} loading="eager" decoding="async" />
      </figure>
    </div>

    <div class="showcase-copy">
      <p class="text-sm font-semibold tracking-normal text-[color:var(--green)]">{copy.settings.kicker}</p>
      <h2 class="mt-3 text-3xl font-semibold leading-tight tracking-normal text-[color:var(--ink)] sm:text-4xl">
        {copy.settings.title}
      </h2>
      <p class="mt-4 leading-7 text-[color:var(--muted)]">
        {copy.settings.body}
      </p>
      <p class="mt-3 leading-7 text-[color:var(--muted)]">
        {copy.settings.beforeStrong}<strong class="font-semibold text-[color:var(--ink)]">{copy.settings.strong}</strong>{copy.settings.afterStrong}
      </p>
      <div class="mt-7 grid gap-3 sm:grid-cols-2">
        {
          copy.settings.points.map(([title, description]) => (
            <div class="rounded-[8px] border border-[color:var(--line)] bg-white px-4 py-3">
              <p class="text-sm font-semibold text-[color:var(--ink)]">{title}</p>
              <p class="mt-1 text-sm leading-6 text-[color:var(--muted)]">{description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <div class="osd-showcase">
    <DynamicOsdDemo />
    <div class="osd-copy">
      <p class="text-sm font-semibold tracking-normal text-[color:var(--orange)]">{copy.osd.kicker}</p>
      <h2 class="mt-3 text-3xl font-semibold leading-tight tracking-normal text-[color:var(--ink)] sm:text-4xl">
        {copy.osd.title}
      </h2>
      <p class="mt-4 leading-7 text-[color:var(--muted)]">
        {copy.osd.body}
      </p>
    </div>
  </div>
</section>

<section class="border-t border-[color:var(--line)] bg-white">
  <div class="mx-auto grid max-w-6xl gap-8 px-5 py-16 lg:grid-cols-[1fr_1fr]">
    <div>
      <p class="text-sm font-semibold tracking-normal text-[color:var(--blue)]">{copy.download.kicker}</p>
      <h2 class="mt-3 text-3xl font-semibold leading-tight tracking-normal text-[color:var(--ink)]">
        {copy.download.title}
      </h2>
      <p class="mt-4 leading-7 text-[color:var(--muted)]">
        {copy.download.body}
      </p>
    </div>
    <div class="feature-card min-w-0 p-6">
      <p class="text-sm font-semibold text-[color:var(--muted)]">SHA-256</p>
      <code class="mt-3 block max-w-full overflow-x-auto whitespace-nowrap rounded-[8px] bg-[color:var(--surface-muted)] p-3 text-sm text-[color:var(--ink)]">{SITE.sha256}</code>
      <div class="mt-5 flex flex-col gap-3 sm:flex-row">
        <a class="inline-flex min-h-11 items-center justify-center rounded-[8px] bg-[color:var(--blue)] px-4 py-2 text-sm font-semibold text-white" href={SITE.downloadUrl}>
          {copy.download.button}
        </a>
        <a class="inline-flex min-h-11 items-center justify-center rounded-[8px] border border-[color:var(--line)] px-4 py-2 text-sm font-semibold" href={SITE.releasesUrl}>
          {copy.download.releases}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .product-showcase {
    display: grid;
    grid-template-columns: minmax(0, 0.96fr) minmax(320px, 1.04fr);
    align-items: center;
    gap: clamp(40px, 7vw, 96px);
  }

  .screenshot-stack {
    position: relative;
    min-height: clamp(360px, 42vw, 510px);
    perspective: 900px;
  }

  .stacked-shot {
    position: absolute;
    margin: 0;
    width: min(56%, 292px);
    transform-origin: center;
    transition: transform 180ms ease;
  }

  .stacked-shot img {
    display: block;
    width: 100%;
    height: auto;
    filter:
      drop-shadow(0 24px 36px rgba(18, 20, 23, 0.2))
      drop-shadow(0 8px 14px rgba(18, 20, 23, 0.12));
    transition:
      filter 180ms ease,
      transform 180ms ease;
    will-change: transform;
  }

  .stacked-shot:hover img {
    filter:
      drop-shadow(0 32px 44px rgba(18, 20, 23, 0.24))
      drop-shadow(0 12px 18px rgba(18, 20, 23, 0.14));
    transform: translateY(-6px) scale(1.018);
  }

  .stacked-shot-general {
    top: 5%;
    left: 10%;
    z-index: 1;
    transform: rotate(-8deg) translateY(8px);
  }

  .stacked-shot-mouse {
    right: 10%;
    bottom: 5%;
    z-index: 2;
    transform: rotate(7deg) translateY(-2px);
  }

  .screenshot-stack:hover .stacked-shot-general {
    transform: rotate(-9deg) translate(-6px, 0);
  }

  .screenshot-stack:hover .stacked-shot-mouse {
    transform: rotate(8deg) translate(6px, -8px);
  }

  .showcase-copy {
    max-width: 520px;
  }

  .osd-showcase {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(280px, 0.92fr);
    align-items: center;
    gap: clamp(30px, 6vw, 72px);
    margin-top: clamp(56px, 8vw, 92px);
    padding-top: clamp(42px, 6vw, 72px);
    border-top: 1px solid var(--line);
  }

  .osd-copy {
    max-width: 410px;
  }

  @media (max-width: 900px) {
    .product-showcase,
    .osd-showcase {
      grid-template-columns: 1fr;
    }

    .screenshot-stack {
      min-height: clamp(360px, 92vw, 560px);
    }

    .stacked-shot {
      width: min(66%, 300px);
    }

    .showcase-copy,
    .osd-copy {
      max-width: none;
    }
  }

  @media (max-width: 520px) {
    .screenshot-stack {
      min-height: 410px;
    }

    .stacked-shot {
      width: min(76%, 280px);
    }

    .stacked-shot-general {
      left: 0;
      transform: rotate(-6deg) translateY(10px);
    }

    .stacked-shot-mouse {
      right: 0;
      transform: rotate(6deg) translateY(-4px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .stacked-shot img {
      transition: none;
    }

    .stacked-shot {
      transition: none;
    }

    .stacked-shot:hover img {
      transform: none;
    }

    .screenshot-stack:hover .stacked-shot-general,
    .screenshot-stack:hover .stacked-shot-mouse {
      transform: none;
    }
  }
</style>
