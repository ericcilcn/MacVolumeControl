---
interface Props {
  class?: string;
  label?: string;
  state?: number;
}

const { class: className = "", label = "Rolume volume level", state = 10 } = Astro.props;
const base = import.meta.env.BASE_URL;
const baseSrc = `${base}icon-wheel/rolume-icon-lights-off-1024.png`;
const wheelLitSrc = `${base}icon-wheel/rolume-wheel-lit-1024.png`;
const level = Math.min(10, Math.max(0, Math.round(state)));

const pct = (px: number) => `${((px / 1024) * 100).toFixed(3)}%`;
const wheelLeft = pct(428);
const wheelRight = pct(428);
const wheelSlices = [
  { slot: 10, top: 242, bottom: 274 },
  { slot: 9, top: 286, bottom: 320 },
  { slot: 8, top: 338, bottom: 374 },
  { slot: 7, top: 399, bottom: 432 },
  { slot: 6, top: 464, bottom: 494 },
  { slot: 5, top: 530, bottom: 560 },
  { slot: 4, top: 594, bottom: 628 },
  { slot: 3, top: 656, bottom: 692 },
  { slot: 2, top: 712, bottom: 746 },
  { slot: 1, top: 762, bottom: 792 },
].map((slice) => ({
  ...slice,
  clipTop: pct(slice.top),
  clipBottom: pct(1024 - slice.bottom),
}));
---

<span
  class:list={["layered-rolume-icon", className]}
  style={`--initial-level: ${level}; --wheel-lit-image: url("${wheelLitSrc}");`}
  aria-label={label}
  role="img"
>
  <img class="icon-base" src={baseSrc} alt="" decoding="async" draggable="false" />
  {
    wheelSlices.map((slice) => (
      <span
        class="wheel-slice"
        style={`--slot: ${slice.slot}; --clip-top: ${slice.clipTop}; --clip-bottom: ${slice.clipBottom}; --clip-left: ${wheelLeft}; --clip-right: ${wheelRight};`}
      />
    ))
  }
</span>

<style>
  .layered-rolume-icon {
    --level: var(--icon-level, var(--initial-level));
    position: relative;
    display: block;
    width: var(--icon-size, 220px);
    aspect-ratio: 1;
    user-select: none;
  }

  .icon-base,
  .wheel-slice {
    position: absolute;
    display: block;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .icon-base {
    object-fit: contain;
  }

  .wheel-slice {
    background-image: var(--wheel-lit-image);
    background-position: center;
    background-repeat: no-repeat;
    background-size: contain;
    clip-path: inset(var(--clip-top) var(--clip-right) var(--clip-bottom) var(--clip-left));
    opacity: clamp(0, calc(var(--level) - var(--slot) + 1), 1);
    pointer-events: none;
  }
</style>
