---
const base = import.meta.env.BASE_URL;
const withBase = (path: string) => `${base}${path.replace(/^\/+/, "")}`;
---

<div class="dynamic-osd-demo" data-dynamic-osd style="--osd-volume: 0%;" aria-label="Rolume OSD volume preview">
  <div class="dynamic-osd" aria-live="polite">
    <div class="osd-title">R27U81</div>
    <div class="osd-row">
      <img class="osd-speaker osd-speaker-small" src={withBase("/osd-icons/speaker.svg")} alt="" decoding="async" draggable="false" />
      <div class="osd-track" aria-hidden="true">
        <span class="osd-fill"></span>
      </div>
      <img class="osd-speaker osd-speaker-loud" src={withBase("/osd-icons/speaker-wave-3.svg")} alt="" decoding="async" draggable="false" />
    </div>
    <span class="sr-only"><span data-osd-label>0</span>%</span>
  </div>
</div>

<script is:inline>
  (() => {
    const demos = document.querySelectorAll("[data-dynamic-osd]");

    demos.forEach((root) => {
      let volume = 0;
      const label = root.querySelector("[data-osd-label]");

      const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

      const render = () => {
        const rounded = Math.round(volume);
        root.style.setProperty("--osd-volume", `${rounded}%`);
        if (label) label.textContent = String(rounded);
      };

      const updateFromScroll = () => {
        const rect = root.getBoundingClientRect();
        const viewportHeight = window.innerHeight || document.documentElement.clientHeight || 1;
        const progress = clamp((viewportHeight - rect.top) / viewportHeight, 0, 1);
        volume = progress * 100;
        render();
      };

      window.addEventListener("scroll", updateFromScroll, { passive: true });
      window.addEventListener("resize", updateFromScroll, { passive: true });

      updateFromScroll();
    });
  })();
</script>

<style>
  .dynamic-osd-demo {
    display: grid;
    width: min(100%, 620px);
    justify-self: center;
    place-items: center;
    min-height: 190px;
    padding: 8px 0;
  }

  .dynamic-osd {
    width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 44px;
    background: rgba(142, 142, 142, 0.92);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.22),
      0 24px 42px rgba(11, 13, 18, 0.18);
    color: white;
    padding: 24px 38px 25px;
    --osd-hover-y: 0px;
    --osd-scale: 1;
    transform: translateY(var(--osd-hover-y)) scale(var(--osd-scale));
    transform-origin: center;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
    will-change: transform;
  }

  .dynamic-osd-demo:hover .dynamic-osd,
  .dynamic-osd-demo:focus-within .dynamic-osd {
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.24),
      0 32px 52px rgba(11, 13, 18, 0.22);
    --osd-hover-y: -6px;
    --osd-scale: 1.015;
  }

  .osd-title {
    font-size: 1.22rem;
    font-weight: 760;
    line-height: 1;
    letter-spacing: 0;
  }

  .osd-row {
    display: grid;
    grid-template-columns: 36px minmax(180px, 1fr) 58px;
    gap: 19px;
    align-items: center;
    margin-top: 22px;
  }

  .osd-track {
    height: 9px;
    min-width: 180px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.34);
  }

  .osd-fill {
    display: block;
    width: var(--osd-volume, 42%);
    height: 100%;
    border-radius: inherit;
    background: white;
    transition: width 120ms ease;
  }

  .osd-speaker {
    display: block;
    width: 54px;
    height: auto;
    user-select: none;
  }

  .osd-speaker-small {
    width: 31px;
  }

  .osd-speaker-loud {
    width: 54px;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .dynamic-osd-demo {
      width: min(100%, 430px);
      min-height: 160px;
    }

    .dynamic-osd {
      border-radius: 30px;
      padding: 20px 22px 23px;
    }

    .osd-row {
      grid-template-columns: 31px minmax(118px, 1fr) 46px;
      gap: 14px;
    }

    .osd-track {
      min-width: 118px;
    }

    .osd-speaker {
      width: 45px;
    }

    .osd-speaker-small {
      width: 28px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dynamic-osd {
      transition: none;
    }

    .dynamic-osd-demo:hover .dynamic-osd,
    .dynamic-osd-demo:focus-within .dynamic-osd {
      --osd-hover-y: 0px;
      --osd-scale: 1;
    }

    .osd-fill {
      transition: none;
    }
  }
</style>
